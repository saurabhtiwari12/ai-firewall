# Database
MONGODB_URI=mongodb://localhost:27017/ai-firewall
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# API
PORT=5000
NODE_ENV=development

# Threat Intelligence
ABUSEIPDB_API_KEY=your-abuseipdb-api-key
SPAMHAUS_API_KEY=your-spamhaus-api-key

# Firewall Engine
BACKEND_API_URL=http://localhost:5000
FW_DRY_RUN=true
FW_INTERFACE=eth0
FW_CAPTURE_FILTER=tcp or udp
FW_FLOW_IDLE_TIMEOUT=120
FW_FLOW_ACTIVE_TIMEOUT=600

# ML Models
MODEL_PATH=./models
ML_CONFIDENCE_THRESHOLD=0.7

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3003
